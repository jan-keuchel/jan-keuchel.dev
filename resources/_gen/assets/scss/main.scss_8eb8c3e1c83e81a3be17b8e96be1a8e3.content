html,body{height:100%;margin:0;padding:0}body{background-color:#121212;color:#e0e0e0;font-family:-apple-system,BlinkMacSystemFont,segoe ui,Roboto,Oxygen,Ubuntu,Cantarell,sans-serif;line-height:1.6;display:flex;flex-direction:column;min-height:100vh}.content-body{max-width:750px;margin:0 auto;padding:1rem;width:100%;flex:1}.content-body p>a,.content-body li>a{color:#f24049;text-decoration:none;transition:background-color .1s ease;padding:.2em 0;border-radius:.2em}.content-body p>a:hover,.content-body li>a:hover{color:#f24049;text-decoration:none;background-color:rgba(242,64,73,.2)}.content-body img{width:90%;max-width:100%;height:auto;display:block;margin:1em auto}.content-body .svg-fill-background svg{width:90%;height:100%;filter:invert(1)hue-rotate(180deg)}.site-header{max-width:750px;margin:0 auto;width:100%;padding:1.5rem 1rem}footer{max-width:750px;margin:0 auto;width:100%;padding:1rem;text-align:center;flex-shrink:0}.px24-svg{width:24px;height:24px;color:#fff}.personal-links a{text-decoration:none}.obligaroty-links{text-decoration:none;color:#999eff;font-size:.75em}.obligaroty-links:hover{color:#999eff;text-decoration:underline}h1,h2,h3,h4,h5,h6{color:#e0e0e0;font-weight:600;line-height:1.2;margin-top:0}h1{font-size:2.2rem}h2{font-size:1.8rem;margin-bottom:1rem}h3{font-size:1.4rem}p{margin:0 0 1rem;color:#e0e0e0}#pgp-key{font-size:1.25em;overflow-x:auto;padding:1rem;background-color:#2c2c2c;border-radius:4px}code{background-color:#2c2c2c;color:#f24049;padding:.2rem .4rem;border-radius:3px;font-family:courier new,Courier,monospace;font-size:.9em}pre code{background-color:initial;color:inherit;padding:0}main{flex:1;padding:1rem 0}.highlight-block{padding:.8em 1em;margin:.75rem 0;font-size:1rem;color:#e0e0e0}.highlight-note{background:color-mix(in srgb,#121212 90%,#64B5F6);border-left:6px solid color-mix(in srgb,#121212 60%,#64B5F6)}.highlight-warning{background:color-mix(in srgb,#121212 90%,#F2545B);border-left:6px solid color-mix(in srgb,#121212 60%,#F2545B)}.highlight-hint{background:color-mix(in srgb,#121212 90%,#4DE6AC);border-left:6px solid color-mix(in srgb,#121212 60%,#4DE6AC)}.highlight-important{background:color-mix(in srgb,#121212 90%,#FF8F33);border-left:6px solid color-mix(in srgb,#121212 60%,#FF8F33)}.toc{background:color-mix(in srgb,#121212 95%,white);border-radius:.5em;padding:.5em 0;margin-bottom:2rem}.toc .heading{padding-left:1rem}.site-header{background-color:#121212;padding:1.5rem 2rem;border-bottom:1px solid #333;display:flex;flex-direction:column;align-items:center;text-align:center}.site-header .header-title{margin-bottom:1rem}.site-header .header-title .title-text{margin:0;color:#e0e0e0}.site-header .header-title .title-text .title-link{color:inherit;text-decoration:none;transition:color .2s ease}.site-header .header-title .title-text .title-link:hover{color:#f24049}.site-header .site-nav .nav-list{display:flex;justify-content:center;gap:1.5rem;list-style:none;padding:0;margin:0}.site-header .site-nav .nav-item .nav-link{color:#e0e0e0;text-decoration:none;font-size:1.1rem;transition:color .2s ease}.site-header .site-nav .nav-item .nav-link:hover{color:#f24049}.site-header .site-nav .nav-item .is-active{color:#f24049;font-weight:700}.cards-container{display:flex;flex-direction:column;gap:1.5rem;padding:1rem 0}.card{background-color:#121212;border:1px solid #333;border-radius:4px;padding:0;transition:transform .2s ease,box-shadow .2s ease,background-color .2s ease;box-shadow:0 2px 5px rgba(255,255,255,3%)}.card:hover{transform:translateY(-3px);box-shadow:0 5px 15px rgba(255,255,255,5%);background-color:#1a1a1a}.card .card-link{display:block;padding:1.2rem;color:inherit;text-decoration:none;height:100%;width:100%}.card .card-link:hover{color:inherit}.card .card-title{margin:0 0 .5rem;font-size:1.3rem;color:#e0e0e0}.card .card-summary{margin:0 0 .8rem;color:#888;font-size:.95rem}.card .card-date{display:block;color:#888;font-size:.85rem}footer{background-color:#121212;padding:2rem;border-top:1px solid #333;margin-top:2rem;text-align:center}footer p{margin:0 0 1rem;color:#e0e0e0;font-size:1rem}footer ul{list-style:none;padding:0;margin:0;display:flex;justify-content:center;gap:1.5rem}footer ul li a{color:#e0e0e0;text-decoration:none;font-size:1rem;transition:color .2s ease}footer ul li a:hover{color:#f44}