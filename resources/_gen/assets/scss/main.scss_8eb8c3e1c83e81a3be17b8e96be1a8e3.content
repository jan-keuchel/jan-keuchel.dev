.cards-container{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;padding:1rem}.card{border:1px solid #ddd;border-radius:8px;background:#fff;box-shadow:0 2px 4px rgba(0,0,0,.1);transition:transform .2s ease,box-shadow .2s ease;padding:1.5rem}.card:hover{transform:translateY(-5px);box-shadow:0 5px 15px rgba(0,0,0,.1)}.card-title{margin-top:0;color:#333}.card-title a{text-decoration:none;color:inherit}.card-summary{color:#666;margin-bottom:1rem}.card-date{color:#999;font-size:.9rem}.site-header{text-align:center;padding:1.5rem 0;background-color:#fff;border-bottom:1px solid #eee}.header-title{margin-bottom:1rem}.title-text{margin:0;font-size:2rem;color:#333}.title-text .title-link{text-decoration:none;color:inherit}.site-nav{display:flex;justify-content:center}.nav-list{list-style:none;padding:0;margin:0;display:flex;gap:1.5rem;flex-wrap:wrap}.nav-item{margin:0}.nav-link{text-decoration:none;color:#333;font-size:1rem;padding:.5rem 1rem;border-radius:4px;transition:all .2s ease}.nav-link:hover{color:#fff;background-color:#3498db}@media screen and (max-width:600px){.nav-list{flex-direction:column;gap:.5rem;align-items:center}}