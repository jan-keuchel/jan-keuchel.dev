.cards-container{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;padding:1rem}.card{border:1px solid #ddd;border-radius:8px;background:#fff;box-shadow:0 2px 4px rgba(0,0,0,.1);transition:transform .2s ease,box-shadow .2s ease;padding:1.5rem}.card:hover{transform:translateY(-5px);box-shadow:0 5px 15px rgba(0,0,0,.1)}.card-title{margin-top:0;color:#333}.card-title a{text-decoration:none;color:inherit}.card-summary{color:#666;margin-bottom:1rem}.card-date{color:#999;font-size:.9rem}